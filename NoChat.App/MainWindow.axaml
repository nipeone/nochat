<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NoChat.App.ViewModels;assembly=NoChat.App"
        xmlns:models="clr-namespace:NoChat.Core.Models;assembly=NoChat.Core"
        xmlns:views="clr-namespace:NoChat.App.Views;assembly=NoChat.App"
        x:Class="NoChat.App.MainWindow"
        Title="NoChat - 局域网聊天"
        Width="1000" Height="660"
        MinWidth="800" MinHeight="500"
        ExtendClientAreaToDecorationsHint="False">
    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A000000"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A000000"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="64,280,*" RowDefinitions="*">
        <!-- 左侧导航 -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Margin="0,16,0,0">
                <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,24">
                    <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource AccentBrush}" HorizontalAlignment="Center">
                        <TextBlock x:Name="UserInitial" Text="N" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Ellipse Width="10" Height="10" Fill="#50C878" HorizontalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="NavChats" Content="💬 聊天" Margin="8,4" HorizontalContentAlignment="Left" BorderThickness="0" Click="OnNavChats"/>
                <Button x:Name="NavGroups" Content="👥 群组" Margin="8,4" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Click="OnNavGroups"/>
                <Button x:Name="NavSettings" Content="⚙ 设置" Margin="8,4" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Click="OnNavSettings"/>
                <StackPanel VerticalAlignment="Bottom" Margin="8,0,8,16">
                    <TextBlock Text="深色模式" FontSize="12" Opacity="0.8" Margin="8,0"/>
                    <ToggleSwitch x:Name="DarkModeToggle" IsCheckedChanged="OnDarkModeToggled"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 中间：LAN Users -->
        <Border Grid.Column="1" Background="{DynamicResource ContentBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}">
            <Grid RowDefinitions="Auto,Auto,Auto,*">
                <TextBlock Grid.Row="0" Text="LAN 用户" FontSize="16" FontWeight="SemiBold" Margin="16,16,16,8"/>
                <TextBox Grid.Row="1" x:Name="SearchBox" Watermark="搜索..." Margin="12,0,12,8" MinHeight="36"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="12,0,12,12">
                    <TextBox x:Name="ManualHostBox" Text="{Binding ManualHostIp, Mode=TwoWay}" Watermark="对方 IP，如 192.168.2.27" MinWidth="140" MinHeight="32"/>
                    <Button Content="添加主机" Click="OnAddManualHostClick" MinHeight="32"/>
                </StackPanel>
                <ListBox Grid.Row="3" x:Name="FriendList" ItemsSource="{Binding Friends}" SelectionChanged="OnFriendSelected"
                         Margin="8,0,8,8" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:UserInfo">
                            <Grid ColumnDefinitions="Auto,*" Margin="8,6">
                                <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding DisplayName, Converter={StaticResource FirstCharConverter}}" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Medium"/>
                                        <Ellipse Width="8" Height="8" Fill="#50C878" VerticalAlignment="Center" IsVisible="{Binding IsOnline}"/>
                                        <TextBlock Text="在线" FontSize="11" Foreground="#50C878" VerticalAlignment="Center" IsVisible="{Binding IsOnline}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding MachineName}" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 右侧：聊天 或 设置 -->
        <Grid Grid.Column="2" x:Name="ContentArea">
            <!-- 聊天视图 -->
            <Grid x:Name="ChatPanel" RowDefinitions="Auto,*,Auto" IsVisible="True">
                <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                            <TextBlock x:Name="ChatPartnerInitial" Text="?" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ChatTitle" Text="选择一位好友开始聊天" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ChatSubtitle" Text="" FontSize="12" Opacity="0.8"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" x:Name="MessageScroll" VerticalScrollBarVisibility="Auto" Margin="16,12">
                    <ItemsControl x:Name="MessageList" ItemsSource="{Binding CurrentMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:MessageDisplayItem">
                                <Border Margin="0,6" Padding="14,10" CornerRadius="12" MaxWidth="420"
                                        HorizontalAlignment="{Binding IsFromMe, Converter={StaticResource BoolToAlignmentConverter}}"
                                        Background="{Binding IsFromMe, Converter={StaticResource BoolToBrushConverter}}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Message.SenderName}" FontSize="12" Opacity="0.85"/>
                                        <TextBlock Text="{Binding Message.Content}" TextWrapping="Wrap" FontSize="14"/>
                                        <TextBlock Text="{Binding Message.SentAt, StringFormat='{}{0:HH:mm}'}" FontSize="11" Opacity="0.65" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}" Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <TextBox Grid.Column="0" Text="{Binding InputText, Mode=TwoWay}" Watermark="输入消息..." MinHeight="40" Margin="0,0,8,0" KeyDown="OnInputKeyDown"/>
                        <Button Grid.Column="1" Content="发送" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Margin="0,0,8,0" Click="OnSendClick"/>
                        <Button Grid.Column="2" Content="文件" Margin="0,0,8,0" Click="OnSendFileClick"/>
                        <Button Grid.Column="3" Content="文件夹" Click="OnSendFolderClick"/>
                    </Grid>
                </Border>
            </Grid>
            <!-- 设置视图 -->
            <ContentControl x:Name="SettingsPanel" IsVisible="False"/>
        </Grid>
    </Grid>
</Window>
