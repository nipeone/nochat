<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NoChat.App.ViewModels;assembly=NoChat"
        xmlns:models="clr-namespace:NoChat.Core.Models;assembly=NoChat.Core"
        xmlns:views="clr-namespace:NoChat.App.Views;assembly=NoChat"
        x:Class="NoChat.App.MainWindow"
        Title="NoChat - 局域网聊天"
        Width="1000" Height="660"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="False">
    <!-- Avalonia 11.1+：样式 Setter 的 Value 若为整数，在控件分离时可能触发 Int32→Double 的 InvalidCastException（如双击导致视觉树更新），故此处使用小数形式强制为 double -->
    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8.0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13.0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8.0"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A000000"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A000000"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="64,280,*" RowDefinitions="*">
        <!-- 左侧导航 -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}">
            <Grid Margin="0,16,0,0" RowDefinitions="Auto,*,Auto">
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="4.0" Margin="0,0,0,24">
                    <Border Width="40" Height="40" CornerRadius="20.0" Background="{DynamicResource AccentBrush}" HorizontalAlignment="Center">
                        <TextBlock x:Name="UserInitial" Text="N" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Ellipse Width="10" Height="10" Fill="#50C878" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="1" VerticalAlignment="Top" Spacing="4">
                    <Button x:Name="NavChats" Margin="4,4" Padding="8" BorderThickness="0" Click="OnNavChats" ToolTip.Tip="聊天">
                        <PathIcon Data="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="NavGroups" Margin="4,4" Padding="8" Background="Transparent" BorderThickness="0" Click="OnNavGroups" ToolTip.Tip="群组">
                        <PathIcon Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="NavSettings" Margin="4,4" Padding="8" Background="Transparent" BorderThickness="0" Click="OnNavSettings" ToolTip.Tip="设置">
                        <PathIcon Data="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8" Spacing="2">
                    <TextBlock Text="深色模式" FontSize="12" Opacity="0.8" HorizontalAlignment="Center"/>
                    <ToggleSwitch x:Name="DarkModeToggle" 
                                  IsCheckedChanged="OnDarkModeToggled" 
                                  HorizontalAlignment="Center" 
                                  OnContent="" 
                                  OffContent="" 
                                  Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 中间：LAN Users -->
        <Border Grid.Column="1" Background="{DynamicResource ContentBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}">
            <Grid RowDefinitions="Auto,Auto,*">
                <TextBlock Grid.Row="0" Text="LAN 用户" FontSize="16" FontWeight="SemiBold" Margin="16,16,16,8"/>
                <TextBox Grid.Row="1" x:Name="SearchBox" Watermark="搜索..." Margin="12,0,12,12" MinHeight="36"/>
                <ListBox Grid.Row="2" x:Name="FriendList" ItemsSource="{Binding Friends}" SelectionChanged="OnFriendSelected"
                         Margin="8,0,8,8" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:FriendItemViewModel">
                            <Grid ColumnDefinitions="Auto,*" Margin="8,6">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="改备注" Click="OnEditRemarkClick"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding DisplayNameForList, Converter={StaticResource FirstCharConverter}}" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2.0">
                                    <StackPanel Orientation="Horizontal" Spacing="6.0">
                                        <TextBlock Text="{Binding DisplayNameForList}" FontSize="14" FontWeight="Medium"/>
                                        <Ellipse Width="8" Height="8" Fill="#50C878" VerticalAlignment="Center" IsVisible="{Binding IsOnline}"/>
                                        <TextBlock Text="在线" FontSize="11" Foreground="#50C878" VerticalAlignment="Center" IsVisible="{Binding IsOnline}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding MachineName}" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 右侧：聊天 或 设置 -->
        <Grid Grid.Column="2" x:Name="ContentArea">
            <!-- 聊天视图 -->
            <Grid x:Name="ChatPanel" RowDefinitions="Auto,*,Auto" IsVisible="True">
                <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Width="36" Height="36" CornerRadius="18.0" Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                            <TextBlock x:Name="ChatPartnerInitial" Text="?" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ChatTitle" Text="选择一位好友开始聊天" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ChatSubtitle" Text="" FontSize="12" Opacity="0.8"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" x:Name="MessageScroll" VerticalScrollBarVisibility="Auto" Margin="16,12"
                              Background="{DynamicResource ChatAreaBrush}">
                    <ItemsControl x:Name="MessageList" ItemsSource="{Binding CurrentMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:MessageDisplayItem">
                                <Border Margin="0,6" Padding="14,10" CornerRadius="12.0" MaxWidth="420"
                                        HorizontalAlignment="{Binding IsFromMe, Converter={StaticResource BoolToAlignmentConverter}}"
                                        Background="{Binding IsFromMe, Converter={StaticResource BoolToBrushConverter}}"
                                        BorderThickness="0">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="复制" Click="OnCopyMessageClick"/>
                                            <MenuItem Header="撤回" Click="OnRecallMessageClick" IsVisible="{Binding CanRecall}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Message.SenderName}" FontSize="12" Opacity="0.85"/>
                                            <Button Content="撤回" Click="OnRecallMessageClick" IsVisible="{Binding CanRecall}"
                                                    Padding="6,2" FontSize="11" Background="Transparent" BorderThickness="0" Foreground="#888"/>
                                        </StackPanel>
                                        <SelectableTextBlock Text="{Binding Message.Content}" TextWrapping="Wrap" FontSize="14"
                                                             IsVisible="{Binding Message.IsRecalled, Converter={StaticResource InverseBoolConverter}}"/>
                                        <TextBlock Text="已撤回" FontSize="13" FontStyle="Italic" Opacity="0.7"
                                                   IsVisible="{Binding Message.IsRecalled}"/>
                                        <TextBlock Text="{Binding Message.SentAt, Converter={StaticResource DateTimeToLocalStringConverter}}" FontSize="11" Opacity="0.65" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}" Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBox Grid.Column="0" Text="{Binding InputText, Mode=TwoWay}" Watermark="输入消息，Enter 发送" MinHeight="40" Margin="0,0,8,0" KeyDown="OnInputKeyDown"/>
                        <Button Grid.Column="1" Content="➤ 发送" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Margin="0,0,8,0" Click="OnSendClick" MinWidth="88"/>
                        <Button Grid.Column="2" Content="📎" ToolTip.Tip="发送文件或文件夹" MinWidth="44" MinHeight="40">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="发送文件" Click="OnSendFileClick"/>
                                    <MenuItem Header="发送文件夹" Click="OnSendFolderClick"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
            <!-- 设置视图 -->
            <ContentControl x:Name="SettingsPanel" IsVisible="False"/>
        </Grid>
    </Grid>
</Window>
